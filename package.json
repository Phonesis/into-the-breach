    "bake-elevenlabs-mg-extra": "node scripts/bake-elevenlabs-mg-extra.mjs",
    "bake-elevenlabs-smg": "node scripts/bake-elevenlabs-smg.mjs",
    "bake-elevenlabs-more-sfx": "node scripts/bake-elevenlabs-more-sfx.mjs",
    "bake-elevenlabs-underfire": "node scripts/bake-elevenlabs-underfire.mjs",
