{
  "name": "into-the-breach",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "GITHUB_PAGES=true vite build",
    "generate-vehicle-svgs": "node scripts/generate-vehicle-svgs.mjs",
    "preview": "vite preview",
    "preview:pages": "npm run build:pages && vite preview --base /into-the-breach/",
    "bake-sounds": "node scripts/bake-gun-sounds.mjs",
    "bake-engines": "node scripts/bake-engine-sounds.mjs",
    "bake-infantry-death": "node scripts/bake-infantry-death.mjs",
    "generate-menu-music": "python3 scripts/generate-menu-music.py && ffmpeg -y -i public/music/menu-theme.wav -c:a libvorbis -q:a 6 public/music/menu-theme.ogg"
  },
  "dependencies": {
    "three": "^0.172.0"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  }
}